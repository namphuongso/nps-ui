{
  "name": "@namphuongso/nps-ui",
  "version": "0.1.0",
  "description": "React UI component library built on Ant Design by NP Technology.",
  "type": "module",
  "main": "./dist/nps-ui.cjs",
  "module": "./dist/nps-ui.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/style.css",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nps-ui.js",
      "require": "./dist/nps-ui.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "vite build"
  },
  "peerDependencies": {
    "antd": "^5.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "keywords": [
    "react",
    "ui",
    "ant-design",
    "antd",
    "component-library",
    "nps-ui",
    "namphuong",
    "tailwind"
  ],
  "author": "NP Technology <contact@namphuong.tech>",
  "license": "MIT",
  "homepage": "https://namphuongso.github.io/nps-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/namphuongso/nps-ui.git"
  },
  "bugs": {
    "url": "https://github.com/namphuongso/nps-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
